# 基础配置
ENVIRONMENT=development  # 开发环境
DEBUG=True
APP_NAME=smart-wardrobe

# 数据库配置（开发可用SQLite简化，生产用PostgreSQL）
DATABASE_URL=sqlite:///./wardrobe.db  # 或 postgresql://user:password@localhost:5432/wardrobe
DATABASE_ECHO=False  # 是否打印SQL日志

# JWT安全配置（开发可用临时密钥，生产需用openssl生成）
JWT_SECRET_KEY=98542fb8f5f939f3417f090feb5055005c941fa505b18554332409f6549c2175  # 生产环境用：openssl rand -hex 32
ACCESS_TOKEN_EXP_MINUTES=30
JWT_REFRESH_SECRET_KEY=dev-refresh-secret
REFRESH_TOKEN_EXP_DAYS=7

# CORS配置（允许前端域名）
CORS_ALLOW_ORIGINS=["http://localhost:8080"]  # 前端开发地址

# AI服务配置（根据实际接口填写，暂时可留空或用测试地址）
LEFFA_ENDPOINT=http://10.108.3.78:7860/api/predict  # Leffa试穿接口
LEFFA_TIMEOUT=120
#FASHIONCLIP_ENDPOINT=  # 标签识别接口
BAICHUAN_API_URL=https://api.baichuan-ai.com/v1/chat/completions  # 百川大模型接口
BAICHUAN_API_KEY=sk-079a6fcaec5589b27d7281b99c768e78

# 图片存储（开发用本地存储）
OBJECT_STORAGE_TYPE=local
MEDIA_ROOT=./uploads  # 本地图片保存路径