# 应用配置
APP_NAME=SmartWardrobe
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO
LOG_FILE=./smartwardrobe.log

# 数据库配置
DATABASE_URL=sqlite:///./smartwardrobe.db
DATABASE_ECHO=False
DATABASE_POOL_SIZE=5

# JWT配置
JWT_SECRET_KEY=replace-with-your-secret-key-using-openssl-rand-hex-32
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS配置
FRONTEND_ORIGIN=http://localhost:8080

# AI服务配置
LEFFA_ENDPOINT=http://127.0.0.1:8000
FASHIONCLIP_ENDPOINT=https://fashionclip-api.example.com/tag
BAICHUAN_API_KEY=sk-079a6fcaec5589b27d7281b99c768e78
BAICHUAN_ENDPOINT=https://api.baichuan-ai.com/v1/chat/completions

# Baichuan 模型名称（如需更换请修改）
BAICHUAN_MODEL=Baichuan4-Air

# 可选功能开关
ENABLE_TRYON=False
ENABLE_RECOMMENDATIONS=True

# 图片存储配置
OBJECT_STORAGE_TYPE=local
IMAGE_STORAGE_PATH=./uploads
IMAGE_MAX_SIZE=5242880  # 5MB
IMAGE_QUALITY=85

# 天气服务配置
WEATHER_API_KEY=replace-with-your-weather-api-key
WEATHER_ENDPOINT=https://api.weatherapi.com/v1/current.json