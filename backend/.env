# 数据库配置
DATABASE_URL=sqlite:///./smartwardrobe.db

# 功能开关（开启后注册 /tryon 与 /recommendations，才会写入试穿与推荐历史）
ENABLE_TRYON=true
ENABLE_RECOMMENDATIONS=true

# JWT 配置（生产环境请使用：openssl rand -hex 32 生成）
JWT_SECRET_KEY=your-secret-key-here
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_CLOCK_SKEW_SECONDS=60

# 前端地址（CORS）
FRONTEND_ORIGIN=http://localhost:8080

# ========== AI 服务配置（必需）==========

# 1. KM 可美 token 网关 — 虚拟试穿（OpenAI 协议 POST /v1/images/generations，不再使用 Leffa）
# 鉴权：Authorization: Bearer sk-xxx
KEMI_GATEWAY_BASE_URL=https://token.xinhankr.com
KEMI_GATEWAY_API_KEY=your-kemi-gateway-api-key-here
# 在网关文档中选支持参考图/图生图的 model 名称填入
KEMI_TRYON_IMAGE_MODEL=
# 可选：KEMI_TRYON_PROMPT=...
# 可选：KEMI_TRYON_POLL_INTERVAL_SEC=2.0
# 可选：KEMI_TRYON_POLL_TIMEOUT_SEC=300

# 2. 百川大模型 API Key（标签识别和推荐功能）
# 获取方式：访问百川大模型官网注册并获取 API Key
BAICHUAN_API_KEY=your-baichuan-api-key-here
BAICHUAN_ENDPOINT=https://api.baichuan-ai.com/v1/chat/completions
BAICHUAN_MODEL=Baichuan4-Air