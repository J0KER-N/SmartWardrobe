# ========================================================
# SmartWardrobe 环境配置模板
# ========================================================
# 复制此文件为 .env，并填入你的配置。
# 敏感值（标有 🔑 的字段）优先从环境变量读取。
# ========================================================

# --- 应用配置 ---
APP_NAME=SmartWardrobe
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO

# --- 数据库配置 ---
# SQLite（开发用）:
DATABASE_URL=sqlite:///./smartwardrobe.db
# PostgreSQL（生产用，取消下面这行注释）:
# DATABASE_URL=postgresql+asyncpg://smartwardrobe:password@localhost:5432/smartwardrobe
DATABASE_ECHO=False
DATABASE_POOL_SIZE=5

# --- Redis 配置（可选，用于缓存层）---
REDIS_URL=redis://localhost:6379/0
REDIS_TTL_SECONDS=300

# --- JWT 配置（🔑 生产环境必须通过环境变量 JWT_SECRET_KEY 注入）---
JWT_SECRET_KEY=
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS 配置 ---
FRONTEND_ORIGIN=http://localhost:8080

# --- AI 服务配置 ---
# 🔑 KEMI_GATEWAY_API_KEY 通过环境变量注入
KEMI_GATEWAY_BASE_URL=https://token.xinhankr.com
KEMI_TRYON_IMAGE_MODEL=doubao-seedream-5-0-260128
KEMI_TRYON_IMAGES_PATH=/api/v3/images/generations
KEMI_TRYON_DURATION=5
ENABLE_TRYON=false
ENABLE_RECOMMENDATIONS=false

# 🔑 BAICHUAN_API_KEY 通过环境变量注入
BAICHUAN_ENDPOINT=https://api.baichuan-ai.com/v1/chat/completions

# --- 图片存储配置（🔑 S3 等生产存储需额外配置） ---
OBJECT_STORAGE_TYPE=local
IMAGE_STORAGE_PATH=./uploads
IMAGE_MAX_SIZE=5242880
IMAGE_QUALITY=85

# --- 天气服务配置 ---
# 🔑 WEATHER_API_KEY 通过环境变量注入
WEATHER_ENDPOINT=https://api.weatherapi.com/v1/current.json

# --- Celery 任务队列（可选，P3 规划） ---
# CELERY_BROKER_URL=redis://localhost:6379/1
# CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --- Sentry 监控（可选） ---
# SENTRY_DSN=https://your-dsn@sentry.io/your-project
